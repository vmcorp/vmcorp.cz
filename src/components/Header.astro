---
import { type Lang, t, getAlternateUrl } from '@/i18n';
import { Menu, X, ChevronDown } from '@lucide/astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const altUrl = getAlternateUrl(Astro.url, lang === 'en' ? 'cs' : 'en');
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-900/60 backdrop-blur-xl backdrop-saturate-150 border-b border-white/[0.06]" id="site-header">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href={i.urls.home} class="flex items-center gap-3 group">
      <svg class="w-9 h-9 transition-all group-hover:drop-shadow-[0_0_12px_rgba(200,168,78,0.35)]" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
        <rect width="36" height="36" rx="8" fill="#151517"/>
        <path d="M8 10 L13 10 L18 22 L23 10 L28 10 L18 27 Z" fill="#C8A84E"/>
      </svg>
      <span class="text-lg tracking-tight">
        <span class="font-bold text-dark-50">VM</span><span class="font-normal text-dark-100">Corp</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label={lang === 'cs' ? 'Hlavní navigace' : 'Main navigation'}>
      <!-- Services dropdown -->
      <div class="relative group" id="services-dropdown">
        <button class="flex items-center gap-1 text-dark-100 hover:text-gold-400 transition-colors text-sm font-medium" aria-expanded="false" aria-haspopup="true" id="services-btn">
          {i.nav.services}
          <ChevronDown class="w-4 h-4" />
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-200" id="services-panel" role="menu">
          <div class="bg-dark-700 border border-dark-400/50 rounded-xl p-2 min-w-[240px] shadow-xl">
            <a href={i.urls.servicesAi} class="block px-4 py-2.5 rounded-lg text-sm text-dark-100 hover:text-gold-400 hover:bg-dark-600 transition-colors">
              {i.nav.servicesAi}
            </a>
            <a href={i.urls.servicesArch} class="block px-4 py-2.5 rounded-lg text-sm text-dark-100 hover:text-gold-400 hover:bg-dark-600 transition-colors">
              {i.nav.servicesArch}
            </a>
            <a href={i.urls.servicesHucz} class="block px-4 py-2.5 rounded-lg text-sm text-dark-100 hover:text-gold-400 hover:bg-dark-600 transition-colors">
              {i.nav.servicesHucz}
            </a>
          </div>
        </div>
      </div>

      <a href={i.urls.about} class="text-dark-100 hover:text-gold-400 transition-colors text-sm font-medium">
        {i.nav.about}
      </a>

      <a href={i.urls.contact} class="text-dark-100 hover:text-gold-400 transition-colors text-sm font-medium">
        {i.nav.contact}
      </a>

      <!-- Language switcher -->
      <a href={altUrl} hreflang={i.altLang.code} class="text-dark-200 hover:text-gold-400 transition-colors text-sm font-medium border border-dark-400 px-3 py-1.5 rounded-lg hover:border-gold-400/50">
        {i.altLang.label}
      </a>

      <!-- CTA -->
      <a href={i.urls.contact} class="btn-primary !px-6 !py-2.5 text-sm">
        {i.nav.letsChat}
      </a>
    </nav>

    <!-- Mobile controls -->
    <div class="flex items-center gap-3 lg:hidden">
      <a href={altUrl} hreflang={i.altLang.code} class="text-dark-200 hover:text-gold-400 transition-colors text-sm font-medium border border-dark-400 px-3 py-1.5 rounded-lg">
        {i.altLang.label}
      </a>
      <button id="mobile-toggle" class="text-dark-100 hover:text-gold-400 transition-colors p-2" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <Menu class="w-6 h-6" id="menu-open-icon" />
        <X class="w-6 h-6 hidden" id="menu-close-icon" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-dark-800/95 backdrop-blur-lg border-t border-dark-400/50">
    <nav class="max-w-7xl mx-auto px-6 py-6 flex flex-col gap-4" aria-label={lang === 'cs' ? 'Mobilní navigace' : 'Mobile navigation'}>
      <a href={i.urls.servicesAi} class="text-dark-100 hover:text-gold-400 transition-colors py-2 text-sm">
        {i.nav.servicesAi}
      </a>
      <a href={i.urls.servicesArch} class="text-dark-100 hover:text-gold-400 transition-colors py-2 text-sm">
        {i.nav.servicesArch}
      </a>
      <a href={i.urls.servicesHucz} class="text-dark-100 hover:text-gold-400 transition-colors py-2 text-sm">
        {i.nav.servicesHucz}
      </a>
      <div class="border-t border-dark-400/50 pt-4 mt-2">
        <a href={i.urls.about} class="block text-dark-100 hover:text-gold-400 transition-colors py-2 text-sm">
          {i.nav.about}
        </a>
        <a href={i.urls.contact} class="block text-dark-100 hover:text-gold-400 transition-colors py-2 text-sm">
          {i.nav.contact}
        </a>
      </div>
      <a href={i.urls.contact} class="btn-primary text-center mt-2 text-sm">
        {i.nav.letsChat}
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const openIcon = document.getElementById('menu-open-icon')!;
  const closeIcon = document.getElementById('menu-close-icon')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    openIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
