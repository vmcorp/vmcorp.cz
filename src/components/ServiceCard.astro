---
import { Brain, Blocks, Globe, Target, Heart, Server, Mic, Layers, Zap, Shield, Eye, Database, AlertTriangle } from '@lucide/astro';

interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
  linkText?: string;
  bullets?: string[];
}

const { title, description, icon, href, linkText, bullets } = Astro.props;

const iconMap: Record<string, any> = {
  brain: Brain,
  blocks: Blocks,
  globe: Globe,
  target: Target,
  heart: Heart,
  server: Server,
  mic: Mic,
  layers: Layers,
  zap: Zap,
  shield: Shield,
  eye: Eye,
  database: Database,
  'alert-triangle': AlertTriangle,
};
const Icon = iconMap[icon] || Brain;
---

<div class="card group h-full flex flex-col">
  <div class="w-12 h-12 bg-gold-400/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-gold-400/20 transition-colors">
    <Icon class="w-6 h-6 text-gold-400" />
  </div>
  <h3 class="text-xl font-semibold mb-3">{title}</h3>
  <p class="text-dark-100 leading-relaxed text-sm mb-4">{description}</p>
  {bullets && bullets.length > 0 && (
    <ul class="space-y-2 mt-auto">
      {bullets.map((b) => (
        <li class="flex items-start gap-2 text-sm text-dark-100">
          <span class="text-gold-400 mt-0.5 shrink-0">&rarr;</span>
          <span>{b}</span>
        </li>
      ))}
    </ul>
  )}
  {href && (
    <a href={href} class="inline-flex items-center gap-2 mt-6 text-gold-400 text-sm font-medium hover:text-gold-300 transition-colors group/link">
      {linkText || 'Learn more'}
      <span class="transition-transform group-hover/link:translate-x-1">&rarr;</span>
    </a>
  )}
</div>
