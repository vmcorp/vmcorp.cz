---
import { Award, Clock, Briefcase, Building2, Mic } from '@lucide/astro';

interface Props {
  items: string[];
}

const { items } = Astro.props;
const icons = [Award, Clock, Briefcase, Building2, Mic];
---

<section class="border-y border-gold-400/10 bg-dark-800/30" style="box-shadow: inset 0 0 60px rgba(200, 168, 78, 0.04), 0 0 30px rgba(200, 168, 78, 0.03);">
  <div class="max-w-7xl mx-auto px-6 py-6">
    <div class="flex flex-wrap justify-center gap-x-10 gap-y-4">
      {items.map((item, idx) => {
        const Icon = icons[idx % icons.length];
        return (
          <div class="flex items-center gap-2 text-dark-100 text-sm">
            <Icon class="w-4 h-4 text-gold-400" />
            <span>{item}</span>
          </div>
        );
      })}
    </div>
  </div>
</section>
