---
import { type Lang, t } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
---

<footer class="border-t border-dark-400/30 bg-dark-900">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={i.urls.home} class="flex items-center gap-3 mb-4" aria-label="VMCorp">
          <svg class="w-9 h-9" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" rx="8" fill="#151517"/>
            <path d="M8 10 L13 10 L18 22 L23 10 L28 10 L18 27 Z" fill="#C8A84E"/>
          </svg>
          <span class="text-lg tracking-tight">
            <span class="font-bold text-dark-50">VM</span><span class="font-normal text-dark-100">Corp</span>
          </span>
        </a>
        <p class="text-dark-100 text-sm max-w-xs">
          {i.footer.tagline}
        </p>
      </div>

      <!-- Services links -->
      <div>
        <h4 class="text-sm font-semibold text-dark-50 mb-4">{i.footer.services}</h4>
        <ul class="space-y-3">
          <li>
            <a href={i.urls.servicesAi} class="text-dark-100 hover:text-gold-400 transition-colors text-sm">
              {i.nav.servicesAi}
            </a>
          </li>
          <li>
            <a href={i.urls.servicesArch} class="text-dark-100 hover:text-gold-400 transition-colors text-sm">
              {i.nav.servicesArch}
            </a>
          </li>
          <li>
            <a href={i.urls.servicesHucz} class="text-dark-100 hover:text-gold-400 transition-colors text-sm">
              {i.nav.servicesHucz}
            </a>
          </li>
        </ul>
      </div>

      <!-- Company info -->
      <div>
        <h4 class="text-sm font-semibold text-dark-50 mb-4">{i.footer.company}</h4>
        <ul class="space-y-3 mb-4">
          <li>
            <a href={i.urls.about} class="text-dark-100 hover:text-gold-400 transition-colors text-sm">
              {i.nav.about}
            </a>
          </li>
          <li>
            <a href={i.urls.contact} class="text-dark-100 hover:text-gold-400 transition-colors text-sm">
              {i.nav.contact}
            </a>
          </li>
        </ul>
        <div class="space-y-2 text-sm text-dark-100 border-t border-dark-400/30 pt-4">
          <p>{i.footer.companyName}</p>
          <p>{i.footer.address}</p>
          <p class="pt-2">
            <span class="text-dark-200">IC:</span> {i.footer.ic}
          </p>
          <p>
            <span class="text-dark-200">DIC:</span> {i.footer.dic}
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
