---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import SocialProofBar from '@/components/SocialProofBar.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTASection from '@/components/CTASection.astro';
import { t } from '@/i18n';

const lang = 'en' as const;
const i = t(lang);
const { home, urls } = i;

const logoMap: Record<string, string> = {
  'LangChain': '/logos/langchain.svg',
  'CrewAI': '/logos/crewai.svg',
  'Python': '/logos/python.svg',
  'Node.js': '/logos/node.js.svg',
  'PHP': '/logos/php.svg',
  'TypeScript': '/logos/typescript.svg',
  'FastAPI': '/logos/fastapi.svg',
  'Next.js': '/logos/next.js.svg',
  'PostgreSQL': '/logos/postgresql.svg',
  'MongoDB': '/logos/mongodb.svg',
  'Redis': '/logos/redis.svg',
  'RabbitMQ': '/logos/rabbitmq.svg',
  'GraphQL': '/logos/graphql.svg',
  'OpenTelemetry': '/logos/opentelemetry.svg',
  'Grafana': '/logos/grafana.svg',
  'Prometheus': '/logos/prometheus.svg',
  'Docker': '/logos/docker.svg',
  'Kubernetes': '/logos/kubernetes.svg',
  'Terraform': '/logos/terraform.svg',
  'Ansible': '/logos/ansible.svg',
  'N8N': '/logos/n8n.svg',
  'AWS': '/logos/aws.svg',
  'GCP': '/logos/gcp.svg',
  'Azure': '/logos/azure.svg',
  'LangGraph': '/logos/langgraph.svg',
  'LangFuse': '/logos/langfuse.svg',
  'AutoGen': '/logos/autogen.svg',
  'MCP': '/logos/mcp.svg',
  'A2A': '/logos/a2a.svg',
  'REST': '/logos/rest.svg',
  'WebSockets': '/logos/websockets.svg',
  'Mercure': '/logos/mercure.svg',
  'Loki': '/logos/loki.png',
  'Alertmanager': '/logos/alertmanager.svg',
  'OpenAI': '/logos/openai.svg',
  'Anthropic': '/logos/anthropic.svg',
  'React': '/logos/react.svg',
  'Vue.js': '/logos/vuejs.svg',
  'Astro': '/logos/astro.svg',
  'Tailwind CSS': '/logos/tailwindcss.svg',
  'Symfony': '/logos/symfony.svg',
  'MySQL': '/logos/mysql.svg',
  'SQLite': '/logos/sqlite.svg',
  'Pinecone': '/logos/pinecone.svg',
  'Weaviate': '/logos/weaviate.svg',
  'Qdrant': '/logos/qdrant.svg',
  'Milvus': '/logos/milvus.svg',
  'Sentry': '/logos/sentry.svg',
  'Datadog': '/logos/datadog.svg',
  'Nginx': '/logos/nginx.svg',
  'Traefik': '/logos/traefik.svg',
  'ArgoCD': '/logos/argocd.svg',
  'Harbor': '/logos/harbor.svg',
  'Vault': '/logos/vault.svg',
  'MinIO': '/logos/minio.svg',
  'GitHub Actions': '/logos/github-actions.svg',
  'GitLab CI': '/logos/gitlab.svg',
  'Cloudflare': '/logos/cloudflare.svg',
  'Vercel': '/logos/vercel.svg',
  'Supabase': '/logos/supabase.svg',
  'Git': '/logos/git.svg',
  'Linux': '/logos/linux.svg',
  'Stripe': '/logos/stripe.svg',
  'Puppeteer': '/logos/puppeteer.svg',
  'Selenium': '/logos/selenium.svg',
  'Playwright': '/logos/playwright.svg',
};

const allTech = home.techStack.categories.flatMap((cat) => cat.items);
const third = Math.ceil(allTech.length / 3);
const row1 = allTech.slice(0, third);
const row2 = allTech.slice(third, third * 2);
const row3 = allTech.slice(third * 2);
---

<Layout title={home.meta.title} description={home.meta.description} lang={lang}>
  <Hero
    headline={home.hero.headline}
    headlineAccent={home.hero.headlineAccent}
    subheadline={home.hero.subheadline}
    ctaPrimary={{ label: home.hero.ctaPrimary, href: urls.contact }}
    ctaSecondary={{ label: home.hero.ctaSecondary, href: urls.about }}
    large
  />

  <SocialProofBar items={home.socialProof} />

  <!-- What We Do -->
  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {home.pillars.map((pillar, idx) => (
          <div class={`scroll-reveal stagger-${idx + 1}`}>
            <ServiceCard
              title={pillar.title}
              description={pillar.description}
              icon={pillar.icon}
              href={[urls.servicesAi, urls.servicesArch, urls.servicesHucz][idx]}
              linkText="Learn more"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What Sets Us Apart -->
  <section class="py-14 lg:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-10 lg:mb-16 scroll-reveal">
        <span class="section-label">{home.differentiators.label}</span>
        <h2 class="text-3xl lg:text-4xl font-bold">{home.differentiators.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {home.differentiators.cards.map((card, idx) => (
          <div class={`scroll-reveal stagger-${idx + 1}`}>
            <ServiceCard
              title={card.title}
              description={card.description}
              icon={card.icon}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Delivery Model -->
  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-10 lg:mb-16 scroll-reveal">
        <span class="section-label">{home.process.label}</span>
        <h2 class="text-3xl lg:text-4xl font-bold mb-6">{home.process.title}</h2>
        <p class="text-dark-100 text-lg">{home.process.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {home.process.steps.map((step, idx) => (
          <div class={`scroll-reveal stagger-${idx + 1}`}>
            <div class="card h-full">
              <span class="text-gold-400 text-3xl font-bold mb-4 block">{step.number}</span>
              <h3 class="text-lg font-semibold mb-3">{step.title}</h3>
              <p class="text-dark-100 text-sm leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why VMCorp -->
  <section class="py-14 lg:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl scroll-reveal">
        <span class="section-label">{home.why.label}</span>
        <h2 class="text-3xl lg:text-4xl font-bold mb-8">{home.why.title}</h2>
        <div class="space-y-6 text-dark-100 text-lg leading-relaxed">
          <p>{home.why.text}</p>
          <p>{home.why.text2}</p>
          <p class="text-gold-400 font-semibold">{home.why.kpi}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof -->
  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-10 lg:mb-16 scroll-reveal">
        <span class="section-label">{home.proof.label}</span>
        <h2 class="text-3xl lg:text-4xl font-bold">{home.proof.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {home.proof.items.map((item, idx) => (
          <div class={`scroll-reveal stagger-${idx + 1} text-center`}>
            <span class="text-5xl lg:text-6xl font-bold text-gold-400 block mb-3">{item.metric}</span>
            <p class="text-dark-50 font-medium text-lg mb-1">{item.description}</p>
            <p class="text-dark-200 text-sm">{item.industry}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-14 lg:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-6 mb-10">
      <span class="section-label scroll-reveal">{home.techStack.label}</span>
      <p class="text-dark-200 text-sm mt-2 scroll-reveal">{home.techStack.subtitle}</p>
    </div>
    <div class="marquee-container scroll-reveal">
      <div class="marquee-track">
        {[...row1, ...row1].map((item) => (
          <span class="inline-flex items-center gap-2 px-4 py-2.5 md:gap-3 md:px-7 md:py-4 bg-dark-700/50 border border-dark-400/50 rounded-xl text-dark-100 text-sm md:text-xl whitespace-nowrap">
            {logoMap[item] && <img src={logoMap[item]} alt={`${item} logo`} width="28" height="28" loading="lazy" decoding="async" class="w-5 h-5 md:w-8 md:h-8 grayscale brightness-150" />}
            {item}
          </span>
        ))}
      </div>
      <div class="marquee-track-reverse">
        {[...row2, ...row2].map((item) => (
          <span class="inline-flex items-center gap-2 px-4 py-2.5 md:gap-3 md:px-7 md:py-4 bg-dark-700/50 border border-dark-400/50 rounded-xl text-dark-100 text-sm md:text-xl whitespace-nowrap">
            {logoMap[item] && <img src={logoMap[item]} alt={`${item} logo`} width="28" height="28" loading="lazy" decoding="async" class="w-5 h-5 md:w-8 md:h-8 grayscale brightness-150" />}
            {item}
          </span>
        ))}
      </div>
      <div class="marquee-track">
        {[...row3, ...row3].map((item) => (
          <span class="inline-flex items-center gap-2 px-4 py-2.5 md:gap-3 md:px-7 md:py-4 bg-dark-700/50 border border-dark-400/50 rounded-xl text-dark-100 text-sm md:text-xl whitespace-nowrap">
            {logoMap[item] && <img src={logoMap[item]} alt={`${item} logo`} width="28" height="28" loading="lazy" decoding="async" class="w-5 h-5 md:w-8 md:h-8 grayscale brightness-150" />}
            {item}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title={home.cta.title}
    text={home.cta.text}
    buttonLabel={home.cta.button}
    buttonHref={urls.contact}
  />
</Layout>
