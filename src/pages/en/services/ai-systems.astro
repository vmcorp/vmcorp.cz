---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTASection from '@/components/CTASection.astro';
import { t } from '@/i18n';
import { CheckCircle } from '@lucide/astro';

const lang = 'en' as const;
const i = t(lang);
const { ai, urls } = i;
---

<Layout title={ai.meta.title} description={ai.meta.description} lang={lang}>
  <Hero headline={ai.hero.headline} subheadline={ai.hero.subheadline} bgImage="/ai-systems.webp" />

  <!-- What We Build -->
  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-12 scroll-reveal">
        <h2 class="text-3xl font-bold mb-6">{ai.what.title}</h2>
        <p class="text-dark-100 text-lg leading-relaxed">{ai.what.text}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {ai.what.points.map((point, idx) => (
          <div class={`card scroll-reveal stagger-${idx + 1}`}>
            <div class="flex gap-4">
              <CheckCircle class="w-6 h-6 text-gold-400 shrink-0 mt-0.5" />
              <div>
                <h3 class="font-semibold mb-2">{point.title}</h3>
                <p class="text-dark-100 text-sm">{point.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modern AI Architecture -->
  <section class="py-14 lg:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-10 lg:mb-16 scroll-reveal">
        <span class="section-label">{ai.architecture.label}</span>
        <h2 class="text-3xl font-bold mb-6">{ai.architecture.title}</h2>
        <p class="text-dark-100 text-lg">{ai.architecture.subtitle}</p>
      </div>
      <div class="space-y-4 scroll-reveal">
        {ai.architecture.layers.map((layer, idx) => {
          const borderClasses = [
            'border-l-gold-400',
            'border-l-gold-400/80',
            'border-l-gold-400/60',
            'border-l-gold-400/40',
          ];
          return (
            <div class={`card !rounded-xl !p-6 border-l-2 ${borderClasses[idx]}`}>
              <div class="flex flex-col md:flex-row md:items-center gap-4">
                <div class="md:w-1/3">
                  <h3 class="text-lg font-semibold">{layer.name}</h3>
                  <p class="text-dark-200 text-sm mt-1">{layer.description}</p>
                </div>
                <div class="md:w-2/3 flex flex-wrap gap-2">
                  {layer.tools.map((tool) => (
                    <span class="px-3 py-1.5 bg-dark-800/80 border border-dark-400/30 rounded-lg text-dark-100 text-sm">{tool}</span>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-12 scroll-reveal">{ai.process.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {ai.process.steps.map((step, idx) => (
          <div class={`card scroll-reveal stagger-${idx + 1}`}>
            <span class="text-gold-400 text-sm font-semibold">0{idx + 1}</span>
            <h3 class="text-xl font-semibold mt-2 mb-4">{step.title}</h3>
            <p class="text-dark-100 leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Safe AI Systems -->
  <section class="py-14 lg:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-10 lg:mb-16 scroll-reveal">
        <span class="section-label">{ai.safety.label}</span>
        <h2 class="text-3xl font-bold mb-6">{ai.safety.title}</h2>
        <p class="text-dark-100 text-lg">{ai.safety.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {ai.safety.principles.map((principle, idx) => (
          <div class={`scroll-reveal stagger-${idx + 1}`}>
            <ServiceCard
              title={principle.title}
              description={principle.description}
              icon={principle.icon}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="py-14 lg:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-10 lg:mb-16 scroll-reveal">
        <span class="section-label">{ai.cases.label}</span>
        <h2 class="text-3xl font-bold mb-6">{ai.cases.title}</h2>
        <p class="text-dark-100 text-lg">{ai.cases.subtitle}</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {ai.cases.items.map((caseItem, idx) => (
          <div class={`scroll-reveal stagger-${idx + 1}`}>
            <div class="card h-full flex flex-col">
              <span class="text-gold-400 text-sm font-semibold tracking-wider uppercase mb-4">{caseItem.industry}</span>
              <div class="space-y-4 flex-1">
                <div>
                  <h4 class="text-xs font-semibold text-dark-200 uppercase tracking-wider mb-1.5">Problem</h4>
                  <p class="text-dark-100 text-sm leading-relaxed">{caseItem.problem}</p>
                </div>
                <div>
                  <h4 class="text-xs font-semibold text-dark-200 uppercase tracking-wider mb-1.5">Architecture</h4>
                  <p class="text-dark-100 text-sm leading-relaxed">{caseItem.architecture}</p>
                </div>
                <div>
                  <h4 class="text-xs font-semibold text-dark-200 uppercase tracking-wider mb-1.5">Outcome</h4>
                  <p class="text-gold-300 text-sm font-medium leading-relaxed">{caseItem.outcome}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Audience -->
  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl scroll-reveal">
        <h2 class="text-3xl font-bold mb-6">{ai.audience.title}</h2>
        <p class="text-dark-100 text-lg leading-relaxed">{ai.audience.text}</p>
      </div>
    </div>
  </section>

  <CTASection title={ai.cta.title} buttonLabel={ai.cta.button} buttonHref={urls.contact} />
</Layout>
