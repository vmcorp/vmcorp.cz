---
// Root page — detect browser locale and redirect instantly
---

<html lang="cs">
  <head>
    <script is:inline>
      var l = (navigator.language || '').slice(0, 2);
      window.location.replace(l === 'en' ? '/en/' : '/cs/');
    </script>
    <meta http-equiv="refresh" content="0;url=/cs/" />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href="https://vmcorp.cz/cs/" />
    <link rel="alternate" hreflang="cs" href="https://vmcorp.cz/cs/" />
    <link rel="alternate" hreflang="en" href="https://vmcorp.cz/en/" />
    <link rel="alternate" hreflang="x-default" href="https://vmcorp.cz/cs/" />
    <title>VMCorp</title>
  </head>
  <body></body>
</html>
