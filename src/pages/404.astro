---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="404 — VMCorp" description="Stránka nenalezena" lang="cs">
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center px-6">
      <span class="text-8xl font-bold text-gold-400 block mb-4">404</span>
      <h1 class="text-2xl font-semibold text-dark-50 mb-3">Stránka nenalezena</h1>
      <p class="text-dark-100 mb-8 max-w-md mx-auto">Tato stránka neexistuje nebo byla přesunuta.</p>
      <a href="/" class="btn-primary">Zpět na úvodní stránku</a>
    </div>
  </section>
</Layout>
