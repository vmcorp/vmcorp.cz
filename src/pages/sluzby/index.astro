---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTASection from '@/components/CTASection.astro';
import { t } from '@/i18n';

const lang = 'cs' as const;
const i = t(lang);
---

<Layout title={i.services.meta.title} description={i.services.meta.description} lang={lang}>
  <Hero headline={i.services.hero.headline} subheadline={i.services.hero.subheadline} bgImage="/services.webp" />

  <section class="py-14 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {i.services.cards.map((card, idx) => (
          <div class={`scroll-reveal stagger-${Math.min(idx + 1, 4)}`}>
            <ServiceCard
              title={card.title}
              description={card.description}
              icon={card.icon}
              bullets={card.bullets}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title={i.home.cta.title}
    text={i.home.cta.text}
    buttonLabel={i.home.cta.button}
    buttonHref={i.urls.contact}
  />
</Layout>
